; REQUIREMENT:	7.3 - Preemptibility
; PARAMETERS:	
; base_period=250000 
; max_sim_time_horizon=250000
; reduction_core_count=6
; time_core_count=2
; run_time=5000
; BASE TASK:	bathtub
; ACTIONS:		open_valve / wait

; This is a combination of 3.1 - multitask learning and 7.2 - resource handling.
; The goal here is to run bathtub and hgs in parallel, in real-time mode. However:
; (R1) AERA is unable to complete this task, as it cannot find a plan in real time.
; Forward chaining takes too long. Running this in diagnostic mode in 3.1. caused AERA to run indefinitely.
; In real-time mode, we just fail find a plan to the goal.

!def rt_sampling_period 500ms

; ============================
; CONSTANTS
; ============================
!def WL_EMPTY 0             ; empty bathtub
!def WL_FULL 100            ; full bathtub
!def WL_PERFECT 50          ; the water level we want to achieve
!def WL_DELTA 10            ; by how much the water level increases each sampling period

!def V_CLOSED 0             ; valve closed
!def V_OPEN 1               ; valve open

!def DRIVE_START 500ms      ; when to start injecting the drive
!def TIME_LIMIT 5000ms      ; how long the agent has to achieve the goal. minimum time for task success is 600ms.

!def V_INIT V_CLOSED        ; initial value - valve
!def WL_INIT WL_EMPTY       ; initial value - water level

!def p_zero 0
!def pH0 25
!def pS0 p_zero
!def pS1 15

; ============================
; ENTITIES & ONTOLOGIES
; ============================
bathtub:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
water_level:(ont 1) [[SYNC_ONCE now 0 forever root nil]];
valve_status:(ont 1) [[SYNC_ONCE now 0 forever root nil]];

h:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
h_is_a_hand:(mk.val h essence hand 1) |[]
(fact h_is_a_hand 0s:0ms:0us GIGASEC 1 1) [[SYNC_AXIOM now 1 forever stdin nil]]
c:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
c_is_a_cube:(mk.val c essence cube 1) |[]
(fact c_is_a_cube 0s:0ms:0us GIGASEC 1 1) [[SYNC_AXIOM now 1 forever stdin nil]]
c_is_a_hand:(mk.val c essence hand 1) |[]
; This is needed for S3.
(|fact c_is_a_hand 0s:0ms:0us GIGASEC 1 1) [[SYNC_AXIOM now 1 forever stdin nil]]
s:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
s_is_a_sphere:(mk.val s essence sphere 1) |[]
(fact s_is_a_sphere 0s:0ms:0us GIGASEC 1 1) [[SYNC_AXIOM now 1 forever stdin nil]]
s_is_a_hand:(mk.val s essence hand 1) |[]
; This is needed for S3.
(|fact s_is_a_hand 0s:0ms:0us GIGASEC 1 1) [[SYNC_AXIOM now 1 forever stdin nil]]

; ============================
; HEARTBEAT
; ============================

; This is used below in pgm_inject_drive, to continuously inject our goal

b:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
b_is_a_bathtub:(mk.val b essence bathtub 1) |[]
f_b_bathtub:(fact b_is_a_bathtub 0s:0ms:0us GIGASEC 1 1) [[SYNC_AXIOM now 1 forever stdin nil]]


; ============================
; EMULATING THE TASK
; ============================

; As AERA is not interacting with the physical world in this test, we have to emulate it ourselves.
; The e1 (emulator) entity keeps track of the state of the real world.
; This works similarly in hand-grab-sphere.
; Usage: (mk.val e1 emulator_state_bathtub [waterLevel valveState])

e1:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
emulator_state_bathtub:(ont 1) [[SYNC_ONCE now 0 forever root nil]]
; Inject the emulator state into the emulator group.
emulator:(std_grp 2 0 0 0 []) [[SYNC_ONCE now 0 forever root nil COV_OFF 0]]

; Internal state used by the programs to emulate the environment.
; (mk.val e1 emulator_state_hgs [Holding_obj Pos_h Pos_c Pos_s])
e2:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
emulator_state_hgs:(ont 1) [[SYNC_ONCE now 0 forever root nil]]

; This program runs in the primary group to re-inject any (fact (goal (fact (cmd ::)))) into emulator.
pgm_inject_in_emulator_group:(pgm [] []
   (ptn f_G:(fact G:(goal (fact (cmd ::) ::) ::) ::) [])
[]
   ; Only re-inject non-simulation goals.
   (= (is_sim G) false)
[]
   (inj [f_G [SYNC_ONCE (now) 1 1 emulator nil]])
1) |[]
(ipgm pgm_inject_in_emulator_group [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever primary nil 1]

; Initial conditions.
start:(pgm [] [] [] []
   (inj [State1:(mk.val e1 emulator_state_bathtub [WL_INIT V_INIT] 1) []]) ; waterlevel, valve
   (inj [State2:(mk.val e2 emulator_state_hgs [c pH0 pH0 pS0] 1) []])
   (inj []
      (fact State1 After:(now) (+ After rt_sampling_period) 1 1)
      [SYNC_PERIODIC now 1 1 emulator nil]
   )
   (inj []
      (fact State2 After:(now) (+ After rt_sampling_period) 1 1)
      [SYNC_PERIODIC now 1 1 emulator nil]
   )
1) |[]
(ipgm start [] RUN_ONCE rt_sampling_period VOLATILE NOTIFY 1) [[SYNC_ONCE now 0 forever stdin nil 1]]

; Match the emulator state and inject individual mk.val at the same time for each of the state variables as needed.
pgm_inject_mk_vals_from_emulator:(pgm [] []
   (ptn (fact (mk.val e1 emulator_state_bathtub [waterLevel: valveState:] :) After: Before: ::) [])
|[] ; guards
[]
   (inj [new_water_level:(mk.val b water_level waterLevel 1) []])
   (inj []
      (fact new_water_level After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
   (inj [new_valve_state:(mk.val b valve_status valveState 1) []])
   (inj []
      (fact new_valve_state After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
1) |[]
(ipgm pgm_inject_mk_vals_from_emulator [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

; ============================
; NEXT EMULATION STEPS
; ============================

; This is also part of emulating the real world. While AERA predicts what will happen through models,
; here we actually inject facts into the system after specific commands as if we would observe 
; reality reacting to our actions

; Before DRIVE_START, just re-inject the same values.
pgm_before_drive:(pgm [] []
   (ptn (fact (mk.val e1 emulator_state_bathtub [waterLevel: valveState:] :) After: Before: ::) [])
[]
   (< After (+ this.vw.ijt DRIVE_START))
[]
   ; All state variables keep the same value.
   (inj [Next_state:(mk.val e1 emulator_state_bathtub [waterLevel valveState] 1) []])
   (inj []
      (fact Next_state (+ After rt_sampling_period) (+ Before rt_sampling_period) 1 1)
      [SYNC_PERIODIC (+ After rt_sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "next emulator state - before drive" []])
1) |[]
(ipgm pgm_before_drive [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]


; next emulation steps if the agent performed the action OPEN VALVE.
pgm_cmd_open_valve:(pgm [] []
   (ptn (fact G:(goal (fact (cmd open_valve [b ] ::) Cmd_after: Cmd_before: ::) ::) ::) [])
   (ptn (fact (mk.val e1 emulator_state_bathtub [waterLevel: valveState:] :) After: Before: ::) [])
[]
   (= valveState V_CLOSED)
   (= (is_sim G) false)
   (< Cmd_after Before)
   (> Cmd_before After)
[]
   ; Inject the fact that the command was executed.
   (inj [Command:(cmd open_valve [b] 1) []])
   (inj []
      (fact Command (+ After 20ms) Before 1 1)
      [SYNC_ONCE After 1 1 stdin nil]
   )
   ; open valve
   (inj [Next_state:(mk.val e1 emulator_state_bathtub [waterLevel V_OPEN] 1) []])
   (inj []
      (fact Next_state (+ After rt_sampling_period) (+ Before rt_sampling_period) 1 1)
      [SYNC_PERIODIC (+ After rt_sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "pgm OPEN VALVE. new state:" [Next_state]])
1) |[]
(ipgm pgm_cmd_open_valve [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]


; next emulation steps if the agent performed the action WAIT.
pgm_cmd_wait:(pgm [] []
   (ptn (fact G:(goal (fact (cmd wait [b ] ::) Cmd_after: Cmd_before: ::) ::) ::) [])
   (ptn (fact (mk.val e1 emulator_state_bathtub [waterLevel: valveState:] :) After: Before: ::) [])
[]
   (= valveState V_OPEN)
   (= (is_sim G) false)
   (< Cmd_after Before)
   (> Cmd_before After)
[]
   ; Inject the fact that the command was executed.
   (inj [Command:(cmd wait [b] 1) []])
   (inj []
      (fact Command (+ After 20ms) Before 1 1)
      [SYNC_ONCE After 1 1 stdin nil]
   )
   ; increase water_level
   (inj [Next_state:(mk.val e1 emulator_state_bathtub [Next_water_level:(+ waterLevel WL_DELTA) V_OPEN] 1) []])
   (inj []
      (fact Next_state (+ After rt_sampling_period) (+ Before rt_sampling_period) 1 1)
      [SYNC_PERIODIC (+ After rt_sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "pgm WAIT. new state:" [Next_state]])
1) |[]
(ipgm pgm_cmd_wait [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

; Before DRIVE_START, just re-inject the same values.
pgm_before_drive_hgs:(pgm [] []
   (ptn (fact (mk.val e2 emulator_state_hgs [Holding_obj: Pos_h: Pos_c: Pos_s:] :) After: Before: ::) [])
[]
   (< After (+ this.vw.ijt DRIVE_START))
[]
   ; All state variables keep the same value.
   (inj [Next_state:(mk.val e2 emulator_state_hgs [Holding_obj Pos_h Pos_c Pos_s] 1) []])
   (inj []
      (fact Next_state (+ After rt_sampling_period) (+ Before rt_sampling_period) 1 1)
      [SYNC_PERIODIC (+ After rt_sampling_period) 1 1 emulator nil]
   )
1) |[]
(ipgm pgm_before_drive_hgs [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

pgm_cmd_move_h_holding_c:(pgm [] []
   (ptn (fact G:(goal (fact (cmd move [h DeltaP_in:] ::) Cmd_after: Cmd_before: ::) ::) ::) [])
   (ptn (fact (mk.val e2 emulator_state_hgs [Holding_obj: Pos_h: Pos_c: Pos_s:] :) After: Before: ::) [])
[]
   (= Holding_obj c)
   (= (is_sim G) false)
   (< Cmd_after Before)
   (> Cmd_before After)
[]
   ; Limit DeltaP to +/- 20. Inject the fact that the command was executed.
   ; (/ DeltaP_in (dis 0 DeltaP_in))) is DeltaP_in normalized to size 1.
   (inj [Command:(cmd move [h DeltaP:(* (min 20 (dis p_zero DeltaP_in)) (/ DeltaP_in (dis p_zero DeltaP_in)))] 1) []])
   (inj []
      (fact Command (+ After 20ms) Before 1 1)
      [SYNC_ONCE After 1 1 stdin nil]
   )
   ; Move h by DeltaP. c moves with h.
   (inj [Next_state:(mk.val e2 emulator_state_hgs [Holding_obj Next_pos_h:(+ Pos_h DeltaP) Next_pos_h Pos_s] 1) []])
   (inj []
      (fact Next_state (+ After rt_sampling_period) (+ Before rt_sampling_period) 1 1)
      [SYNC_PERIODIC (+ After rt_sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "pgm_cmd_move_h_holding_c from command:" [Command]])
1) |[]
(ipgm pgm_cmd_move_h_holding_c [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

pgm_cmd_move_h_holding_s:(pgm [] []
   (ptn (fact G:(goal (fact (cmd move [h DeltaP_in:] ::) Cmd_after: Cmd_before: ::) ::) ::) [])
   (ptn (fact (mk.val e2 emulator_state_hgs [Holding_obj: Pos_h: Pos_c: Pos_s:] :) After: Before: ::) [])
[]
   (= Holding_obj s)
   (= (is_sim G) false)
   (< Cmd_after Before)
   (> Cmd_before After)
[]
   ; Limit DeltaP to +/- 20. Inject the fact that the command was executed.
   ; (/ DeltaP_in (dis 0 DeltaP_in))) is DeltaP_in normalized to size 1.
   (inj [Command:(cmd move [h DeltaP:(* (min 20 (dis p_zero DeltaP_in)) (/ DeltaP_in (dis p_zero DeltaP_in)))] 1) []])
   (inj []
      (fact Command (+ After 20ms) Before 1 1)
      [SYNC_ONCE After 1 1 stdin nil]
   )
   ; Move h by DeltaP. s moves with h.
   (inj [Next_state:(mk.val e2 emulator_state_hgs [Holding_obj Next_pos_h:(+ Pos_h DeltaP) Pos_c Next_pos_h] 1) []])
   (inj []
      (fact Next_state (+ After rt_sampling_period) (+ Before rt_sampling_period) 1 1)
      [SYNC_PERIODIC (+ After rt_sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "pgm_cmd_move_h_holding_s from command:" [Command]])
   (prb [1 "print" "pgm_cmd_move_h_holding_s new s position:" [Next_state]])
1) |[]
(ipgm pgm_cmd_move_h_holding_s [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

pgm_cmd_move_h_not_holding:(pgm [] []
   (ptn (fact G:(goal (fact (cmd move [h DeltaP_in:] ::) Cmd_after: Cmd_before: ::) ::) ::) [])
   (ptn (fact (mk.val e2 emulator_state_hgs [nil Pos_h: Pos_c: Pos_s:] :) After: Before: ::) [])
[]
   (= (is_sim G) false)
   (< Cmd_after Before)
   (> Cmd_before After)
[]
   ; Limit DeltaP to +/- 20. Inject the fact that the command was executed.
   ; (/ DeltaP_in (dis 0 DeltaP_in))) is DeltaP_in normalized to size 1.
   (inj [Command:(cmd move [h DeltaP:(* (min 20 (dis p_zero DeltaP_in)) (/ DeltaP_in (dis p_zero DeltaP_in)))] 1) []])
   (inj []
      (fact Command (+ After 20ms) Before 1 1)
      [SYNC_ONCE After 1 1 stdin nil]
   )
   ; Move h by DeltaP.
   (inj [Next_state:(mk.val e2 emulator_state_hgs [nil (+ Pos_h DeltaP) Pos_c Pos_s] 1) []])
   (inj []
      (fact Next_state (+ After rt_sampling_period) (+ Before rt_sampling_period) 1 1)
      [SYNC_PERIODIC (+ After rt_sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "pgm_cmd_move_h_not_holding from command:" [Command]])
1) |[]
(ipgm pgm_cmd_move_h_not_holding [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

pgm_cmd_release_h:(pgm [] []
   (ptn (fact G:(goal (fact Command:(cmd release [h] ::) Cmd_after: Cmd_before: ::) ::) ::) [])
   (ptn (fact (mk.val e2 emulator_state_hgs [Holding_obj: Pos_h: Pos_c: Pos_s:] :) After: Before: ::) [])
[]
   (= (is_sim G) false)
   (<> Holding_obj nil)
   (< Cmd_after Before)
   (> Cmd_before After)
[]
   ; Inject the fact that the command was executed.
   (inj []
      (fact Command (+ After 20ms) Before 1 1)
      [SYNC_ONCE After 1 1 stdin nil]
   )
   ; h is now not holding.
   (inj [Next_state:(mk.val e2 emulator_state_hgs [nil Pos_h Pos_c Pos_s] 1) []])
   (inj []
      (fact Next_state (+ After rt_sampling_period) (+ Before rt_sampling_period) 1 1)
      [SYNC_PERIODIC (+ After rt_sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "pgm_cmd_release_h from command:" [Command]])
1) |[]
(ipgm pgm_cmd_release_h [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

pgm_cmd_grab_h:(pgm [] []
   (ptn (fact G:(goal (fact Command:(cmd grab [h] ::) Cmd_after: Cmd_before: ::) ::) ::) [])
   (ptn (fact (mk.val e2 emulator_state_hgs [nil Pos_h: Pos_c: Pos_s:] :) After: Before: ::) [])
[]
   (< (dis Pos_h Pos_s) 0.00001); For h to grab s, they must be at the same position.
   (= (is_sim G) false)
   (< Cmd_after Before)
   (> Cmd_before After)
[]
   ; Inject the fact that the command was executed.
   (inj []
      (fact Command (+ After 20ms) Before 1 1)
      [SYNC_ONCE After 1 1 stdin nil]
   )
   ; We already checked that s is at the hand's position. TODO: What if c is also there? 
   (inj [Next_state:(mk.val e2 emulator_state_hgs [s Pos_h Pos_c Pos_s] 1) []])
   (inj []
      (fact Next_state (+ After rt_sampling_period) (+ Before rt_sampling_period) 1 1)
      [SYNC_PERIODIC (+ After rt_sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "pgm_cmd_grab_h from command:" [Command]])
1) |[]
(ipgm pgm_cmd_grab_h [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

; Match the emulator state and inject individual mk.val at the same time for each of
; the state variables as needed.
pgm_inject_mk_vals_holding:(pgm [] []
   (ptn (fact (mk.val e2 emulator_state_hgs [Holding_obj: Pos_h: Pos_c: Pos_s:] :) After: Before: ::) [])
[]
   (<> Holding_obj nil)
[]
   (inj [Val_holding:(mk.val h holding [Holding_obj] 1) []])
   (inj []
      (fact Val_holding After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
   (inj [Val_pos_h:(mk.val h position Pos_h 1) []])
   (inj []
      (fact Val_pos_h After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
   (inj [Val_pos_c:(mk.val c position Pos_c 1) []])
   (inj []
      (fact Val_pos_c After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
   (inj [Val_pos_s:(mk.val s position Pos_s 1) []])
   (inj []
      (fact Val_pos_s After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
1) |[]
(ipgm pgm_inject_mk_vals_holding [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

; The same as pgm_inject_mk_vals_holding for the case when not holding.
pgm_inject_mk_vals_not_holding:(pgm [] []
   (ptn (fact (mk.val e2 emulator_state_hgs [nil Pos_h: Pos_c: Pos_s:] :) After: Before: ::) [])
|[]
[]
   (inj [Val_holding:(mk.val h holding [] 1) []])
   (inj []
      (fact Val_holding After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
   (inj [Val_pos_h:(mk.val h position Pos_h 1) []])
   (inj []
      (fact Val_pos_h After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
   (inj [Val_pos_c:(mk.val c position Pos_c 1) []])
   (inj []
      (fact Val_pos_c After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
   (inj [Val_pos_s:(mk.val s position Pos_s 1) []])
   (inj []
      (fact Val_pos_s After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
1) |[]
(ipgm pgm_inject_mk_vals_not_holding [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]


; ============================
; MODELS
; ============================


; Bathtub B has valve status V at ti TO-T1.
SB0:(cst [] []
   (fact (mk.val B: essence bathtub :) T0: T1: : :)
   (fact (mk.val B: valve_status V: :) T0: T1: : :)
   (fact (mk.val B: water_level WL: :) T0: T1: : :)
|[]
|[]
[stdin] 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; When I open a bathtub's V_CLOSED valve, then that valve will be OPEN
M_OPEN_VALVE:(mdl [B: (ti T0: T1:)] []
   (fact (cmd open_valve [B:] :) T0_cmd: T1_cmd: : :)
   (fact (mk.val B: valve_status V_OPEN :) T0_rhs: T1_rhs: : :)
[]
   T0_rhs:(+ T0 500ms)
   T1_rhs:(+ T1 500ms)
[]
   T0_cmd:(- T0_rhs 80ms)
   T1_cmd:(- T1_rhs 100ms)
   T0:(- T0_rhs 500ms)
   T1:(- T1_rhs 500ms)
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; If we observe SB0 with CLOSED, then if M0 predicts OPEN, it will be right.
M_OPEN_VALVE_PRECOND:(mdl [] []
   (fact (icst SB0 [] [B: V_CLOSED WL0:] : :) T0: T1: : :)
   (fact (imdl M_OPEN_VALVE [B: (ti T0: T1:)] [T0_rhs: T1_rhs:] : :) T0: T1: : :)
|[]
|[]
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]


; When I wait in the presence of an OPEN bathtub, then it will fill +10 next iteration
M_WAIT:(mdl [B: WL0: (ti T0: T1:)] []
   (fact (cmd wait [B:] :) T0_cmd: T1_cmd: : :)
   (fact (mk.val B: water_level WL1: :) T0_rhs: T1_rhs: : :)
[]
   (< WL0 WL_FULL)
   WL1:(+ WL0 WL_DELTA)
   T0_rhs:(+ T0 500ms)
   T1_rhs:(+ T1 500ms)
[]
   (> WL1 WL_EMPTY)
   WL0:(- WL1 WL_DELTA)
   T0_cmd:(- T0_rhs 80ms)
   T1_cmd:(- T1_rhs 100ms)
   T0:(- T0_rhs 500ms)
   T1:(- T1_rhs 500ms)
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; If we observe SB0 with OPEN, then if M0 predicts WAIT, it will be right.
M_WAIT_PRECOND:(mdl [] []
   (fact (icst SB0 [] [B: V_OPEN WL0:] : :) T0: T1: : :)
   (fact (imdl M_WAIT [B: WL0: (ti T0: T1:)] [WL1: T0_rhs: T1_rhs:] : :) T0: T1: : :)
|[]
|[]
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]


; Hand H has position P.
S0:(cst [] []
   (fact (mk.val H: essence hand :) T0: T1: : :); Changed X to hand.
   (fact (mk.val H: position P: :) T0: T1: : :)
|[]
|[]
[stdin] 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; When I move H by offset DeltaP, then H will be at position P1.
M0:(mdl [H: P0: (ti T0: T1:)] []
   (fact (cmd move [H: DeltaP:] :) T2: T1_cmd: : :); Change T1 to T1_cmd.
   (fact (mk.val H: position P1: :) T1_RHS: T3: : :); Change T1 to T1_RHS.
[]
   P1:(+ P0 DeltaP)
   T1_RHS:(+ T0 500ms)
   T3:(+ T1 500ms)
[]
   (<> P1 P0); Don't make a subgoal that doesn't change anything.
   DeltaP:(- P1 P0)
   T2:(- T1_RHS 80ms); Change 50ms delay to 20ms.
   T1_cmd:(- T3 100ms)
   T0:(- T1_RHS 500ms)
   T1:(- T3 500ms)
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; If we observe state S0 (hand H has position P0), then if M0 predicts something (position P1) it will be right.
M1:(mdl [] []
   (fact (icst S0 [] [H: P0:] : :) T0: T1: : :)
   (fact (imdl M0 [H: P0: (ti T0: T1:)] [DeltaP: P1: T1_RHS: T3:] : :) T0: T1: : :); T2: is not exposed from M0. T1_RHS is also exposed.
|[]
|[]
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; A thing C of kind X occupies position P. (Modified to exclude when C is a hand.)
S3:(cst [] []
   (fact (mk.val C: essence X: :) T0: T1: : :)
   (fact (mk.val C: position P: :) T0: T1: : :)
   (|fact (mk.val C: essence hand :) T0: T1: : :); Don't duplicate S0, which is for hands.
|[]
|[]
[stdin] 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; One hand H is at a position P and another thing C is at the same position and the hand is not holding anything.
S1:(cst [] []
   (fact (icst S0 [] [H: P:] : :) T0: T1: : :)
   (fact (icst S3 [] [C: X: P:] : :) T0: T1: : :); X is also exposed from S3.
   (fact (mk.val H: holding [] :) T0: T1: : :); Change anti-fact to fact of holding [].
|[]
|[]
[stdin] 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; When the hand H is asked to grab whatever, then H will be holding it.
M2:(mdl [H: C: (ti T0: T1:)] []
   (fact (cmd grab [H:] :) T2: T1_cmd: : :); Change T1 to T1_cmd.
   (fact (mk.val H: holding [C:] :) T1_RHS: T3: : :); Change T1 to T1_RHS.
[]
   T1_RHS:(+ T0 500ms); Copy from M0.
   T3:(+ T1 500ms);     Copy from M0.
[]
   T2:(- T1_RHS 80ms);  Copy from M0.
   T1_cmd:(- T3 100ms); Copy from M0.
   T0:(- T1_RHS 500ms); Copy from M0.
   T1:(- T3 500ms);     Copy from M0.
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; M2 will work (hand H will be holding something) if it is at the same position as hand H and H is not already holding anything.
M3:(mdl [] []
   (fact (icst S1 [] [H: P: C: X:] : :) T0: T1: : :); X is also exposed from S1.
   (fact (imdl M2 [H: C: (ti T0: T1:)] [T1_RHS: T3:] : :) T0: T1: : :); T2 is not exposed from M2. T1_RHS is also exposed.
|[]
|[]
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; Hand H and object C are at the same position P and H is already holding C.
S2:(cst [] []
   (fact (icst S0 [] [H: P:] : :) T0: T1: : :)
   (fact (icst S3 [] [C: X: P:] : :) T0: T1: : :); X is also exposed from S3.
   (fact (mk.val H: holding [C:] :) T0: T1: : :)
[]
   (<> C nil); Make sure the object C is not nil.
[]
   (<> C nil); Make sure the object C is not nil.
[stdin] 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; When my hand H is holding a thing C and I release my hand, it is not holding anymore.
M4:(mdl [H: C: T0: T1:] []
   (fact (cmd release [H:] :) T2: T1_cmd: : :); Change T1 to T1_cmd.
   (fact (mk.val H: holding [] :) T1_RHS: T3: : :); Change T1 to T1_RHS. Change anti-fact to fact of holding [].
[]
   T1_RHS:(+ T0 500ms); Copy from M0.
   T3:(+ T1 500ms);     Copy from M0.
[]
   T2:(- T1_RHS 80ms);  Copy from M0.
   T1_cmd:(- T3 100ms); Copy from M0.
   T0:(- T1_RHS 500ms); Copy from M0.
   T1:(- T3 500ms);     Copy from M0.
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; M4 will work (hand H will not be holding some C) if it is at the same position as hand H and H is already holding it.
M5:(mdl [] []
   (fact (icst S2 [] [H: P: C: X:] : :) T0: T1: : :); X is also exposed from S2.
   (fact (imdl M4 [H: C: T0: T1:] [T1_RHS: T3:] : :) T0: T1: : :); T2 is not exposed from M4. T1_RHS is also exposed.
|[]
|[]
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; When model M0 fires the prediction of the next position P1 of hand H, something C will also be at the same position P1.
M6:(mdl [H: C: P0: (ti T0: T1:)] []
   (fact (imdl M0 [H: P0: (ti T0: T1:)] [DeltaP: P1: T1_RHS: T3:] : :) T0_cmd: T1_cmd: : :); Change timings from T1 T3 to T0_cmd T1_cmd. T2 is not exposed from M0. T1_RHS is also exposed.
   (fact (mk.val C: position P1: :) T1_RHS: T3: : :); Fix bug as explained: Change C to P1. Change T1 to T1_RHS.
[]
   T1_RHS:(+ T0 500ms); Repeat from M0.
   T3:(+ T1 500ms);     Repeat from M0.
[]
   T0_cmd:(- T1_RHS 80ms);  Copy from M0.
   T1_cmd:(- T3 100ms);     Copy from M0.
   T0:(- T1_RHS 500ms);     Copy from M0.
   T1:(- T3 500ms);         Copy from M0.
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; When hand H is holding some C and the hand moves to position P1, then C will also be at P1.
; (commented out to allow multitask planning)
M7:(mdl [] []
   (fact (icst S2 [] [H: P: C: X:] : :) T0: T1: : :); X is also exposed from S2.
   (fact (imdl M6 [H: C: P: (ti T0: T1:)] [DeltaP: P1: T1_RHS: T3:] : :) T0: T1: : :); M6 template needs P. T0_M0 T1_M0, DeltaP, P1 and T1_RHS are exposed. T2 is not exposed from M6.
|[]
|[]
[stdin] 1 1 1 1 1) [[SYNC_ONCE now 0 forever primary nil 1]]

; ============================
; DRIVE (aka GOAL)
; ============================

m_drive:(mdl [] []
   ; The goal target timings are the same as the drive timings.
   (fact (mk.val b water_level WL_PERFECT 1) T0: T1: 1 1)
   (fact run T0: T1: ::)
|[]
|[]
[stdin drives] 1 1 1 0 1) [[SYNC_ONCE now 0 forever primary nil 1]]

m_drive_hgs:(mdl [] []
   ; The goal target timings are the same as the drive timings.
   (fact (mk.val s position pS1 1) T0: T1: 1 1)
   (fact run T0: T1: ::)
|[]
|[]
[stdin drives] 1 1 1 0 1) [[SYNC_ONCE now 0 forever primary nil 1]]

pgm_inject_drive:(pgm [] []
   ; This fact repeats periodically (bcs of SYNC_AXIOM in f1). We use it as a "heartbeat".
   (ptn (fact (mk.val b essence bathtub :) After: Before: ::) [])
[]
   (>= After (+ this.vw.ijt DRIVE_START))
[]
   (inj [f_run:(fact run After (+ Before TIME_LIMIT) 1 1) []])
   (inj [G:(goal f_run self nil 1) []])
   (inj []
      ; Delay a little to allow predictions for this sampling period before injecting the drive.
      (fact G T0:(+ After 10ms) T0 1 1)
      [SYNC_ONCE T0 1 forever primary nil]
   )
   (prb [1 "print" "injected drive" []])
1) |[]
(ipgm pgm_inject_drive [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever primary nil 1]