; REQUIREMENT:	1.2 - Acting
; PARAMETERS:	-
; BASE TASK:	-
; ACTIONS:		- 

; This is a basic syntax test for the icmd STOP.

; S T O P
; !dfn (_stop)
; !def (stop args) (icmd _stop args)

; setup pgm with stop command
pgm0:(pgm 
|[]
|[]
|[]
[]
   (stop [])
1) |[]

; instantiate program after 600ms. the application should terminate.
ipgm0:(ipgm pgm0 |[] RUN_ONCE 600ms VOLATILE NOTIFY 1) [[SYNC_ONCE now 0 1 stdin nil 1]]