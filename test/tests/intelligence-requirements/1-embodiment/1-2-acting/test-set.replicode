; S E T
; !dfn (_set : :nb)
; !def (set args) (icmd _set args)

; setup
g1:(std_grp 1 0 0.0 0 [nil]) [[SYNC_ONCE now 0 forever stdin nil COV_ON 0]] ; crucial to set 1st std_grp param (update-period) != 0 here!
g2:(std_grp 1 0 0.0 0 [nil]) [[SYNC_ONCE now 0 forever stdin nil COV_ON 0]] 

; set values
pgm0:(pgm 
|[]
|[] 
|[]
[]
   (set [this.vw.act 0.1])
   (set [this.vw.sln 0.1])
1) |[]

; set values again
pgm1:(pgm 
|[]
|[] 
|[]
[]
   (set [this.vw.act 0.7])
   (set [this.vw.sln 0.7])
1) |[]

; set invalid values - negatives
pgm2:(pgm 
|[]
|[] 
|[]
[]
   (set [this.vw.act -0.7])
   (set [this.vw.sln -0.7])
1) |[]

; set invalid values - >1  
pgm3:(pgm 
|[]
|[] 
|[]
[]
   (set [this.vw.act 11.0])
   (set [this.vw.sln 1.5])
1) |[]

; res: stack overflow error was fixed
pgm4:(pgm 
|[]
|[] 
|[]
[]
   (set [this.vw.res 10]) ; 10 -> x times upr -> upr = 50 -> 500ms left to live. 
1) |[]

pgm5:(pgm 
|[]
|[] 
|[]
[]
   (set [this.vw.res 10]) ; 10 -> x times upr -> upr = 50 -> 500ms left to live. 
1) |[]


; (R1) Setting and averaging works, but there is a caveat: Illegal values (<0/>1) are rounded up/down to 0/1 and included in aggregation. 
; Therefore, for the test above, the aggregation of act and sln is: 
; 0.1 + 0.7 + 0(rounded up) + 1(rounded down) / 4 = 0.45 

; As for setting resilience, we set both programs to live for 500 more ms. Therefore, once AERA exits after 1000ms, pgm4 no longer has a view,
; whereas pgm5 will have a view for 100 more ms, and a resilience value of 2.
; (R2) The documentation states that -1 represents an infinite resilience, but this was changed to the keyword "forever".
ipgm0:(ipgm pgm0 |[] RUN_ONCE 100ms VOLATILE NOTIFY 1) [[SYNC_PERIODIC now 0 forever g1 nil 1]]
ipgm1:(ipgm pgm1 |[] RUN_ONCE 200ms VOLATILE NOTIFY 1) [[SYNC_PERIODIC now 0 forever g1 nil 1]]
ipgm2:(ipgm pgm2 |[] RUN_ONCE 300ms VOLATILE NOTIFY 1) [[SYNC_PERIODIC now 0 forever g1 nil 1]]
ipgm3:(ipgm pgm3 |[] RUN_ONCE 400ms VOLATILE NOTIFY 1) [[SYNC_PERIODIC now 0 forever g1 nil 1]]
ipgm4:(ipgm pgm4 |[] RUN_ONCE 500ms VOLATILE NOTIFY 1) [[SYNC_PERIODIC now 0 3000 g2 nil 1]]
ipgm5:(ipgm pgm5 |[] RUN_ONCE 600ms VOLATILE NOTIFY 1) [[SYNC_PERIODIC now 0 3000 g2 nil 1]]