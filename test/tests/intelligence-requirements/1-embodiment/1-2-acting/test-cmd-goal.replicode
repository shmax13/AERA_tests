; EXTERNAL COMMANDS - GOALS

; Actions: close/open valve

; ============================
; constants
; ============================
!def EMPTY 0
!def FULL 100
!def PERFECT 50
!def WATER_LEVEL_DELTA 13
!def CLOSED 0
!def OPEN 1
!def JUST_CLOSED 2
!def JUST_OPENED 3
!def DRIVE_START 300ms
!def DUMMY_1 500ms

; ============================
; setup entities, ontologies and markers
; ============================
bathtub:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
valve:(ent 1) [[SYNC_ONCE now 1 forever root nil]]

b:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
b_is_a_bathtub:(mk.val b essence bathtub 1) |[]
v:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
v_is_a_valve:(mk.val v essence valve 1) |[]

water_level:(ont 1) [[SYNC_ONCE now 0 forever root nil]];
opening:(ont 1) [[SYNC_ONCE now 0 forever root nil]];

bathtub_is_empty:(mk.val bathtub water_level EMPTY 1) [[SYNC_ONCE now 1 forever primary nil]]
bathtub_is_full:(mk.val bathtub water_level FULL 1) [[SYNC_ONCE now 1 forever primary nil]]
bathtub_is_perfectly_full: (mk.val bathtub water_level PERFECT 1) [[SYNC_ONCE now 1 forever primary nil]]

valve_is_closed:(mk.val valve opening CLOSED 1) [[SYNC_ONCE now 1 forever primary nil]]
valve_is_open:(mk.val valve opening OPEN 1) [[SYNC_ONCE now 1 forever primary nil]]

; ============================
; setup facts - our heartbeats!
; ============================
f_b_bathtub:(fact b_is_a_bathtub 0s:0ms:0us GIGASEC 1 1) [[SYNC_AXIOM now 1 forever stdin nil]]
f_v_valve:(fact v_is_a_valve 0s:0ms:0us GIGASEC 1 1) [[SYNC_AXIOM now 1 forever stdin nil]]


; ============================
; emulate our problem!
; ============================
; (mk.val e1 emulator_state [waterLevel valveState])
e1:(ent 1) [[SYNC_ONCE now 1 forever root nil]]
emulator_state:(ont 1) [[SYNC_ONCE now 0 forever root nil]]
; Inject the emulator state into the emulator group.
emulator:(std_grp 2 0 0 0 []) [[SYNC_ONCE now 0 forever root nil COV_OFF 0]]

; This program runs in the primary group to re-inject any (fact (goal (fact (cmd ::)))) into emulator.
; do we need this?
pgm_inject_in_emulator_group:(pgm [] []
   (ptn f_G:(fact G:(goal (fact (cmd ::) ::) ::) ::) [])
[]
   ; Only re-inject non-simulation goals.
   (= (is_sim G) false)
[]
   (inj [f_G [SYNC_ONCE (now) 1 1 emulator nil]])
1) |[]
(ipgm pgm_inject_in_emulator_group [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever primary nil 1]

; Initial conditions.
start:(pgm [] [] [] []
   (inj [State:(mk.val e1 emulator_state [EMPTY CLOSED] 1) []]) ; waterlevel, valve
   (inj []
      (fact State After:(now) (+ After sampling_period) 1 1)
      [SYNC_PERIODIC now 1 1 emulator nil]
   )
1) |[]
(ipgm start [] RUN_ONCE sampling_period VOLATILE NOTIFY 1) [[SYNC_ONCE now 0 forever stdin nil 1]]

; Match the emulator state and inject individual mk.val at the same time for each of the state variables as needed.
pgm_inject_mk_vals_from_emulator:(pgm [] []
   (ptn (fact (mk.val e1 emulator_state [waterLevel: valveState:] :) After: Before: ::) [])
|[] ; guards
[]
   (inj [new_water_level:(mk.val b water_level waterLevel 1) []])
   (inj []
      (fact new_water_level After Before 1 1)
      [SYNC_PERIODIC After 1 1 stdin nil]
   )
1) |[]
(ipgm pgm_inject_mk_vals_from_emulator [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

; ============================
; drive (goal) stuff
; ============================

m_drive:(mdl [] []
   ; The goal target timings are the same as the drive timings.
   (fact (mk.val b water_level PERFECT 1) T0: T1: 1 1)
   (fact run T0: T1: ::)
|[]
|[]
[stdin drives] 1 1 1 0 1) [[SYNC_ONCE now 0 forever primary nil 1]]

pgm_inject_drive:(pgm [] []
   ; This fact repeats periodically (bcs of SYNC_AXIOM in f1). We use it as a "heartbeat".
   (ptn (fact (mk.val b essence bathtub :) After: Before: ::) [])
[]
   (>= After (+ this.vw.ijt DRIVE_START))
[]
   (inj [f_run:(fact run After (+ Before 500ms) 1 1) []])
   (inj [G:(goal f_run self nil 1) []])
   (inj []
      ; Delay a little to allow predictions for this sampling period before injecting the drive.
      (fact G T0:(+ After 10ms) T0 1 1)
      [SYNC_ONCE T0 1 forever primary nil]
   )
   (prb [1 "print" "injected drive" []])
1) |[]
(ipgm pgm_inject_drive [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever primary nil 1]

; ============================
; PROGRAMS
; ============================
; overflow checker
pgm_overflow:(pgm 
|[]
[]
    (ptn (fact (mk.val b water_level FULL :) After: Before: ::) [])
|[]
[]
   (prb [1 "print" "bathtub overflow!" []])
   (stop [])
1) |[]
ipgm_overflow:(ipgm pgm_overflow |[] RUN_ONCE 0ms VOLATILE NOTIFY 1) [[SYNC_ONCE now 0 1 stdin nil 1]]

; ============================
; NEXT EMULATION STEPS
; ============================

; VALVE CLOSED
pgm0:(pgm [] []
   (ptn (fact (mk.val e1 emulator_state [waterLevel: CLOSED] :) After: Before: ::) [])
   ;(ptn (|fact (mk.val e1 emulator_state [: JUST_OPENED] :) : : ::) [])
   ;(ptn (|fact (mk.val e1 emulator_state [: JUST_CLOSED] :) : : ::) [])
|[]
[]
   ; All state variables keep the same value.
   (inj [Next_state:(mk.val e1 emulator_state [waterLevel CLOSED] 1) []])
   (inj []
      (fact Next_state (+ After sampling_period) (+ Before sampling_period) 1 1)
      [SYNC_PERIODIC (+ After sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "next emulator state - VALVE CLOSED" []])
1) |[]
(ipgm pgm0 [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]


; VALVE OPEN
pgm1:(pgm [] []
   (ptn (fact (mk.val e1 emulator_state [waterLevel: valveState:] :) After: Before: ::) [])
[]
   (= valveState OPEN)
[]
   ; All state variables keep the same value.
   (inj [Next_state:(mk.val e1 emulator_state [(+ waterLevel WATER_LEVEL_DELTA) valveState] 1) []])
   (inj []
      (fact Next_state (+ After sampling_period) (+ Before sampling_period) 1 1)
      [SYNC_PERIODIC (+ After sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "next emulator state - VALVE OPEN" []])
1) |[]
(ipgm pgm1 [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

; VALVE JUST OPENED
pgm2:(pgm [] []
   (ptn (fact (mk.val e1 emulator_state [waterLevel: valveState:] :) After: Before: ::) [])
[]
   (= valveState JUST_OPENED)
[]
   ; All state variables keep the same value.
   (inj [Next_state:(mk.val e1 emulator_state [(+ waterLevel WATER_LEVEL_DELTA) OPEN] 1) []])
   (inj []
      (fact Next_state (+ After sampling_period) (+ Before sampling_period) 1 1)
      [SYNC_PERIODIC (+ After sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "next emulator state - VALVE JUST OPENED" []])
1) |[]
(ipgm pgm2 [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]

; VALVE JUST CLOSED
pgm3:(pgm [] []
   (ptn (fact (mk.val e1 emulator_state [waterLevel: valveState:] :) After: Before: ::) [])
[]
   (= valveState JUST_CLOSED)
[]
   ; All state variables keep the same value.
   (inj [Next_state:(mk.val e1 emulator_state [waterLevel CLOSED] 1) []])
   (inj []
      (fact Next_state (+ After sampling_period) (+ Before sampling_period) 1 1)
      [SYNC_PERIODIC (+ After sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "next emulator state - VALVE JUST CLOSED" []])
1) |[]
(ipgm pgm3 [] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) []
   [SYNC_ONCE now 0 forever emulator nil 1]


; ============================
; DUMMIES TO CHECK EMULATION
; ============================
; open valve at 500ms
dummy0:(pgm 
|[]
[]
   (ptn (fact (mk.val e1 emulator_state [waterLevel: valveState:] :) After: Before: ::) [])
[]
   (= After (+ this.vw.ijt DUMMY_1))
[]
   (inj [Command:(cmd open_valve [] 1) []])
   (inj []
      (fact Command (+ After 20ms) Before 1 1)
      [SYNC_ONCE After 1 1 stdin nil]
   )
   (inj [Next_state:(mk.val e1 emulator_state [(+ waterLevel WATER_LEVEL_DELTA) JUST_OPENED] 1) []])
   (inj []
      (fact Next_state (+ After sampling_period) (+ Before sampling_period) 1 1)
      [SYNC_PERIODIC (+ After sampling_period) 1 1 emulator nil]
   )
   (prb [1 "print" "dummy 0 activated - opening valve!" []])
1) |[]
idummy0:(ipgm dummy0 |[] RUN_ALWAYS MAX_TIME VOLATILE NOTIFY 1) [[SYNC_ONCE now 0 forever emulator nil 1]]